# ── Local database (HP Folio 9470m) ──────────────────────────────────────────
DATABASE_URL=postgresql://medilink:changeme@localhost:5432/medilink

# ── Cloud database (Supabase or AWS RDS) — leave blank to run offline-only ──
CLOUD_DATABASE_URL=

# ── Node identity ─────────────────────────────────────────────────────────────
# Set IS_CLOUD_NODE=true on the cloud server, false/blank on the local laptop
IS_CLOUD_NODE=false
FACILITY_ID=main
SYNC_INTERVAL_SECONDS=30

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── Clinic info (on receipts and kiosk) ──────────────────────────────────────
CLINIC_NAME=MediLink Clinic
CLINIC_ADDRESS=No. 1, Jalan Sehat, Malaysia
CLINIC_PHONE=+60 3-1234 5678

# ── Local payments ────────────────────────────────────────────────────────────
BANK_ACCOUNT_NO=1234567890
BANK_NAME=Maybank

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
